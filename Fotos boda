<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>Sube tus recuerdos · Boda Elizabeth & Juan Carlos</title>

<!-- Google Fonts + Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --gold: #e4b363;
  --gold-light: #f5d589;
  --gold-dark: #c49a3a;
  --blue-deep: #0a1a2f;
  --blue-mid: #0f2a44;
  --blue-soft: #1a3a5c;
  --dark-bg: #050d18;
}

body {
  font-family: 'Montserrat', sans-serif;
  background: linear-gradient(135deg, #0a1a2f 0%, #050d18 100%);
  color: #fef7e8;
  min-height: 100vh;
}

/* Header */
.header {
  background: rgba(10, 26, 47, 0.95);
  backdrop-filter: blur(12px);
  padding: 1.5rem 2rem;
  text-align: center;
  border-bottom: 2px solid var(--gold);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header h1 {
  font-family: 'Cinzel', serif;
  font-size: 1.8rem;
  color: var(--gold);
  letter-spacing: 3px;
}

.header h1 i {
  margin-right: 12px;
}

.header p {
  font-size: 0.85rem;
  opacity: 0.8;
  margin-top: 5px;
}

/* Contenedor principal */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
}

/* Tarjeta de subida */
.upload-card {
  background: rgba(15, 42, 68, 0.6);
  backdrop-filter: blur(10px);
  border-radius: 32px;
  border: 1px solid rgba(228, 179, 99, 0.4);
  padding: 2rem;
  margin-bottom: 2.5rem;
  text-align: center;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.upload-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 40px -15px rgba(0,0,0,0.4);
}

.upload-card h2 {
  color: var(--gold);
  font-family: 'Cinzel', serif;
  margin-bottom: 0.5rem;
}

.upload-card h2 i {
  margin-right: 10px;
}

.upload-area {
  border: 2px dashed var(--gold);
  border-radius: 28px;
  padding: 2.5rem;
  margin: 1.5rem 0;
  cursor: pointer;
  transition: all 0.3s;
  background: rgba(0, 0, 0, 0.3);
}

.upload-area:hover {
  background: rgba(228, 179, 99, 0.08);
  border-color: var(--gold-light);
  transform: scale(1.01);
}

.upload-area i {
  font-size: 3.5rem;
  color: var(--gold);
  margin-bottom: 1rem;
}

.upload-area p {
  font-size: 0.95rem;
}

#fileInput {
  display: none;
}

.preview-container {
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
  margin-top: 20px;
  justify-content: center;
}

.preview-item {
  position: relative;
  width: 120px;
  height: 120px;
  border-radius: 20px;
  overflow: hidden;
  border: 2px solid var(--gold);
  background: #000;
  transition: transform 0.2s;
}

.preview-item:hover {
  transform: scale(1.05);
}

.preview-item img, .preview-item video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.preview-item .remove-btn {
  position: absolute;
  top: 5px;
  right: 5px;
  background: rgba(0,0,0,0.7);
  border-radius: 50%;
  width: 26px;
  height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #ff6b6b;
  font-size: 12px;
  transition: 0.2s;
}

.preview-item .remove-btn:hover {
  background: #ff6b6b;
  color: white;
}

.message-input {
  width: 100%;
  padding: 14px 18px;
  border-radius: 60px;
  border: 1px solid var(--gold);
  background: rgba(255,255,255,0.08);
  color: white;
  margin: 15px 0;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.95rem;
  transition: 0.2s;
}

.message-input:focus {
  outline: none;
  border-color: var(--gold-light);
  background: rgba(255,255,255,0.12);
}

.message-input::placeholder {
  color: rgba(255,255,255,0.4);
}

.btn-submit {
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  border: none;
  padding: 14px 45px;
  border-radius: 60px;
  color: var(--blue-deep);
  font-weight: bold;
  font-size: 1rem;
  cursor: pointer;
  transition: 0.3s;
  margin-top: 10px;
  font-family: 'Montserrat', sans-serif;
}

.btn-submit:hover {
  transform: scale(1.02);
  box-shadow: 0 10px 25px -8px rgba(228,179,99,0.4);
  background: linear-gradient(135deg, var(--gold-light), var(--gold));
}

/* Galería de recuerdos */
.gallery-section {
  background: rgba(10, 26, 47, 0.5);
  backdrop-filter: blur(8px);
  border-radius: 32px;
  padding: 2rem;
  margin-top: 1rem;
  border: 1px solid rgba(228, 179, 99, 0.2);
}

.gallery-section h2 {
  color: var(--gold);
  text-align: center;
  margin-bottom: 1.5rem;
  font-family: 'Cinzel', serif;
}

.gallery-section h2 i {
  margin-right: 10px;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 20px;
}

.gallery-item {
  background: rgba(0,0,0,0.4);
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(228, 179, 99, 0.3);
  transition: all 0.3s;
  cursor: pointer;
}

.gallery-item:hover {
  transform: translateY(-5px);
  border-color: var(--gold);
  box-shadow: 0 15px 30px -12px rgba(0,0,0,0.5);
}

.gallery-item img, .gallery-item video {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

.gallery-item .caption {
  padding: 12px;
  font-size: 0.8rem;
  text-align: center;
  color: var(--gold-light);
  background: rgba(10, 26, 47, 0.8);
  word-break: break-word;
}

/* Modal para ver foto ampliada */
.modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.95);
  z-index: 1000;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.modal.active {
  display: flex;
}

.modal-content {
  max-width: 90%;
  max-height: 90%;
}

.modal-content img, .modal-content video {
  max-width: 100%;
  max-height: 90vh;
  border-radius: 16px;
  border: 2px solid var(--gold);
}

.modal-close {
  position: absolute;
  top: 20px;
  right: 30px;
  font-size: 2rem;
  color: var(--gold);
  cursor: pointer;
}

.loading {
  text-align: center;
  padding: 3rem;
  color: var(--gold);
}

.toast {
  position: fixed;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--gold);
  color: var(--blue-deep);
  padding: 12px 28px;
  border-radius: 60px;
  font-weight: bold;
  z-index: 1001;
  animation: fadeInUp 0.3s ease;
  box-shadow: 0 5px 20px rgba(0,0,0,0.3);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

/* Botón volver a la invitación */
.back-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  border: 1px solid var(--gold);
  color: var(--gold);
  padding: 10px 24px;
  border-radius: 60px;
  text-decoration: none;
  font-size: 0.85rem;
  transition: 0.3s;
  margin-top: 1rem;
}

.back-btn:hover {
  background: var(--gold);
  color: var(--blue-deep);
}

@media (max-width: 650px) {
  .container { padding: 1rem; }
  .gallery-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
  .upload-card { padding: 1.5rem; }
  .header h1 { font-size: 1.3rem; }
}
</style>
</head>
<body>

<div class="header">
  <h1><i class="fas fa-camera-retro"></i> Elizabeth & Juan Carlos</h1>
  <p>Comparte tus fotos y videos del día más especial · Tus recuerdos son nuestro tesoro</p>
</div>

<div class="container">
  <!-- Tarjeta de subida -->
  <div class="upload-card">
    <h2><i class="fas fa-cloud-upload-alt"></i> Sube tu recuerdo</h2>
    <p>Fotos, videos cortos (máx 50MB) · Tu mensaje de cariño</p>
    
    <div class="upload-area" id="uploadArea">
      <i class="fas fa-camera"></i>
      <p>Haz clic o arrastra tus archivos aquí</p>
      <p style="font-size: 0.75rem; margin-top: 8px;">Formatos: JPG, PNG, GIF, MP4, MOV</p>
    </div>
    <input type="file" id="fileInput" multiple accept="image/jpeg,image/png,image/jpg,image/gif,video/mp4,video/quicktime">
    
    <div id="previewList" class="preview-container"></div>
    
    <input type="text" id="messageInput" class="message-input" placeholder="✍️ Escribe tu nombre y un mensaje para los novios... (ej: 'Felicidades de Ana y Carlos 💙')">
    
    <button class="btn-submit" id="submitBtn">
      <i class="fas fa-heart"></i> Enviar mis recuerdos
    </button>
  </div>

  <!-- Galería de recuerdos compartidos -->
  <div class="gallery-section">
    <h2><i class="fas fa-images"></i> Álbum de recuerdos</h2>
    <div id="galleryGrid" class="gallery-grid">
      <div class="loading"><i class="fas fa-spinner fa-pulse"></i> Cargando recuerdos...</div>
    </div>
    <div style="text-align: center; margin-top: 1.5rem;">
      <a href="index.html" class="back-btn"><i class="fas fa-arrow-left"></i> Volver a la invitación</a>
    </div>
  </div>
</div>

<!-- Modal para ver imagen/video ampliado -->
<div id="mediaModal" class="modal">
  <span class="modal-close">&times;</span>
  <div class="modal-content" id="modalContent"></div>
</div>

<script>
// ==================== CONFIGURACIÓN ====================
// 📁 URL de Google Forms para recibir las fotos/videos
// PRIMERO: Crea un Google Forms (te explico cómo abajo)
const GOOGLE_FORM_URL = "https://forms.gle/TU_FORMULARIO_AQUI";

// ==================== MANEJO DE ARCHIVOS ====================
let selectedFiles = [];

const uploadArea = document.getElementById('uploadArea');
const fileInput = document.getElementById('fileInput');
const previewList = document.getElementById('previewList');
const messageInput = document.getElementById('messageInput');
const submitBtn = document.getElementById('submitBtn');

// Click en el área de subida
uploadArea.addEventListener('click', () => fileInput.click());

// Arrastrar y soltar
uploadArea.addEventListener('dragover', (e) => {
  e.preventDefault();
  uploadArea.style.background = 'rgba(228, 179, 99, 0.15)';
});
uploadArea.addEventListener('dragleave', () => {
  uploadArea.style.background = 'rgba(0, 0, 0, 0.3)';
});
uploadArea.addEventListener('drop', (e) => {
  e.preventDefault();
  uploadArea.style.background = 'rgba(0, 0, 0, 0.3)';
  const files = Array.from(e.dataTransfer.files);
  addFiles(files);
});

// Selección de archivos
fileInput.addEventListener('change', (e) => {
  addFiles(Array.from(e.target.files));
  fileInput.value = '';
});

function addFiles(files) {
  const validFiles = files.filter(f => {
    const type = f.type;
    return type.startsWith('image/') || type.startsWith('video/');
  });
  
  validFiles.forEach(file => {
    if (file.size > 50 * 1024 * 1024) {
      alert(`❌ El archivo ${file.name} es muy grande (máx 50MB)`);
      return;
    }
    selectedFiles.push(file);
    createPreview(file);
  });
}

function createPreview(file) {
  const div = document.createElement('div');
  div.className = 'preview-item';
  const index = selectedFiles.length - 1;
  
  if (file.type.startsWith('image/')) {
    const img = document.createElement('img');
    img.src = URL.createObjectURL(file);
    div.appendChild(img);
  } else if (file.type.startsWith('video/')) {
    const video = document.createElement('video');
    video.src = URL.createObjectURL(file);
    video.muted = true;
    video.addEventListener('mouseenter', () => video.play());
    video.addEventListener('mouseleave', () => video.pause());
    div.appendChild(video);
  }
  
  const removeBtn = document.createElement('div');
  removeBtn.className = 'remove-btn';
  removeBtn.innerHTML = '<i class="fas fa-times"></i>';
  removeBtn.onclick = () => {
    selectedFiles.splice(index, 1);
    div.remove();
    URL.revokeObjectURL(file);
  };
  div.appendChild(removeBtn);
  previewList.appendChild(div);
}

function showToast(message) {
  const toast = document.createElement('div');
  toast.className = 'toast';
  toast.innerHTML = `<i class="fas fa-check-circle"></i> ${message}`;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), 3500);
}

// ==================== ENVÍO A GOOGLE FORMS ====================
submitBtn.addEventListener('click', async () => {
  if (selectedFiles.length === 0) {
    alert("📸 Por favor selecciona al menos una foto o video");
    return;
  }
  
  const message = messageInput.value.trim();
  if (!message) {
    alert("✍️ Por favor escribe tu nombre y un mensaje para los novios");
    return;
  }
  
  submitBtn.disabled = true;
  submitBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Preparando enlace...';
  
  const archivosLista = selectedFiles.map(f => f.name).join('\n');
  
  const instrucciones = `
📸 Tienes ${selectedFiles.length} archivo(s) para compartir.

Para que los novios reciban tus recuerdos:

1️⃣ Abre este enlace: ${GOOGLE_FORM_URL}
2️⃣ Escribe tu nombre y mensaje: "${message}"
3️⃣ Sube tus ${selectedFiles.length} archivo(s)
4️⃣ Envía el formulario

✨ Los novios revisarán y agregarán tus recuerdos a la galería.
  `;
  
  alert(instrucciones);
  window.open(GOOGLE_FORM_URL, '_blank');
  
  // Limpiar después del envío
  selectedFiles = [];
  previewList.innerHTML = '';
  messageInput.value = '';
  submitBtn.disabled = false;
  submitBtn.innerHTML = '<i class="fas fa-heart"></i> Enviar mis recuerdos';
  
  showToast('💖 ¡Gracias! Abre el enlace para completar tu envío');
});

// ==================== GALERÍA DE RECUERDOS ====================
// Los recuerdos aprobados se muestran aquí (solo tú los actualizas)
// Puedes editar este arreglo con las URLs de las fotos/videos que apruebes

let approvedMemories = [];

// Cargar desde localStorage (para que persistan tus aprobaciones)
function loadMemoriesFromStorage() {
  const stored = localStorage.getItem('wedding_memories_gallery');
  if (stored) {
    try {
      approvedMemories = JSON.parse(stored);
      renderGallery();
    } catch(e) { console.error(e); }
  } else {
    // Ejemplos iniciales (puedes eliminarlos o editarlos)
    approvedMemories = [
      // { type: "image", url: "https://i.imgur.com/ejemplo.jpg", caption: "Ejemplo de foto", date: "2026-05-02" }
    ];
    renderGallery();
  }
}

function saveMemoriesToStorage() {
  localStorage.setItem('wedding_memories_gallery', JSON.stringify(approvedMemories));
}

function renderGallery() {
  const galleryGrid = document.getElementById('galleryGrid');
  
  if (approvedMemories.length === 0) {
    galleryGrid.innerHTML = `
      <div style="grid-column:1/-1; text-align:center; padding:3rem; color:var(--gold-light);">
        <i class="fas fa-camera" style="font-size:3rem; margin-bottom:1rem; display:block;"></i>
        <p>✨ Pronto aparecerán los recuerdos que nuestros invitados compartan ✨</p>
        <p style="font-size:0.8rem; margin-top:10px;">¡Sube tus fotos y videos para aparecer aquí!</p>
      </div>
    `;
    return;
  }
  
  let html = '';
  approvedMemories.forEach((memory, idx) => {
    if (memory.type === 'image') {
      html += `
        <div class="gallery-item" data-index="${idx}" data-type="image" data-url="${memory.url}">
          <img src="${memory.url}" alt="recuerdo de boda" loading="lazy">
          <div class="caption"><i class="fas fa-heart"></i> ${escapeHtml(memory.caption)}</div>
        </div>
      `;
    } else if (memory.type === 'video') {
      html += `
        <div class="gallery-item" data-index="${idx}" data-type="video" data-url="${memory.url}">
          <video src="${memory.url}" preload="metadata" loading="lazy"></video>
          <div class="caption"><i class="fas fa-video"></i> ${escapeHtml(memory.caption)}</div>
        </div>
      `;
    }
  });
  galleryGrid.innerHTML = html;
  
  // Agregar eventos de clic para abrir modal
  document.querySelectorAll('.gallery-item').forEach(item => {
    item.addEventListener('click', (e) => {
      const type = item.dataset.type;
      const url = item.dataset.url;
      openModal(type, url);
    });
  });
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// Modal
const modal = document.getElementById('mediaModal');
const modalContent = document.getElementById('modalContent');
const modalClose = document.querySelector('.modal-close');

function openModal(type, url) {
  modalContent.innerHTML = '';
  if (type === 'image') {
    const img = document.createElement('img');
    img.src = url;
    modalContent.appendChild(img);
  } else if (type === 'video') {
    const video = document.createElement('video');
    video.src = url;
    video.controls = true;
    video.autoplay = true;
    video.style.maxWidth = '100%';
    video.style.maxHeight = '90vh';
    modalContent.appendChild(video);
  }
  modal.classList.add('active');
}

modalClose.addEventListener('click', () => {
  modal.classList.remove('active');
  modalContent.innerHTML = '';
});

modal.addEventListener('click', (e) => {
  if (e.target === modal) {
    modal.classList.remove('active');
    modalContent.innerHTML = '';
  }
});

// ==================== ADMINISTRACIÓN (para ti, el novio) ====================
// Para agregar fotos/videos aprobados, abre la consola (F12) y escribe:
// 
// addMemory("image", "https://i.imgur.com/tufoto.jpg", "Mensaje de Ana");
// addMemory("video", "https://i.imgur.com/video.mp4", "Baile de los novios");
//
// También puedes editar directamente el arreglo approvedMemories y llamar renderGallery()

window.addMemory = function(type, url, caption) {
  approvedMemories.unshift({ type: type, url: url, caption: caption, date: new Date().toISOString() });
  saveMemoriesToStorage();
  renderGallery();
  showToast('✅ Recuerdo agregado a la galería');
};

window.removeMemory = function(index) {
  if (index >= 0 && index < approvedMemories.length) {
    approvedMemories.splice(index, 1);
    saveMemoriesToStorage();
    renderGallery();
    showToast('🗑️ Recuerdo eliminado');
  }
};

// Cargar galería al iniciar
loadMemoriesFromStorage();

// Instrucciones para el novio
console.log('%c✨ ADMINISTRACIÓN DE RECUERDOS ✨', 'color: #e4b363; font-size: 14px; font-weight: bold;');
console.log('%c📸 Para AGREGAR una foto o video aprobado, usa:', 'color: #fff;');
console.log('%caddMemory("image", "URL_DE_LA_IMAGEN", "Mensaje del invitado")', 'color: #f5d589;');
console.log('%caddMemory("video", "URL_DEL_VIDEO", "Mensaje")', 'color: #f5d589;');
console.log('%c🗑️ Para ELIMINAR: removeMemory(indice)', 'color: #ffaa66;');
console.log('%c💡 Las imágenes se guardan automáticamente en tu navegador', 'color: #aaa;');
</script>
</body>
</html>
